# ── 魔女因子検査 — environment ─────────────────────────────────────────────
# Copy to `.env` and fill in. Everything is build-time public (PUBLIC_*),
# so never put secrets here.

# Canonical origin (no trailing slash). Drives canonical URLs, hreflang,
# OG image URLs, share links and the sitemap. Set at deploy time.
PUBLIC_SITE_URL=https://manosaba-witch-exam.pages.dev

# Trusted zh-CN share landing — the full URL of the deploy-once redirect
# shell on bilibili (tools/bilibili-shell/). When set, zh-CN copy-share text
# and the QR on exported card PNGs use this URL (+ `?r=<tag>`) so links
# pasted into WeChat/QQ carry a domain those apps trust; the shell forwards
# `?r` to the canonical `/r/<tag>/` page. Content releases never require
# touching bilibili — only a canonical-domain change does (edit the shell's
# SITE constant and re-upload).
# PUBLIC_SHARE_URL_ZH_CN=https://www.bilibili.com/toy/Manosaba_WitchfactorTest/index.html

# The author's previous work — a personality test — linked in the site footer.
# Unset falls back to the built-in default below.
# PUBLIC_V1_URL=https://manosaba-test.asachiri.com

# Feedback address. TODO(owner): provision a DEDICATED alias (design spec §9) —
# do NOT ship a personal inbox. The placeholder below is intentionally invalid.
PUBLIC_FEEDBACK_EMAIL=witch-exam-feedback@asachiri.com

# Aggregate-telemetry endpoint (Cloudflare Pages Function, Phase 6). When unset
# the beacon is a console.debug no-op. No user identifiers are ever sent.
# PUBLIC_BEACON_URL=https://manosaba-witch-exam.pages.dev/api/beacon
