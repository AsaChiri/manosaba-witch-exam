---
import '../../../styles/fonts-ja.css'
import CharacterCardPage from '../../../views/CharacterCardPage.astro'
import { listCharacters } from '../../../lib/content'
import type { Locale } from '../../../i18n/config'
import type { WitchCharacter } from '../../../lib/content-schema'

export function getStaticPaths() {
  const locale: Locale = 'ja'
  return listCharacters(locale).map((character: WitchCharacter) => ({
    params: { id: character.id },
    props: { character, locale },
  }))
}

const { character, locale } = Astro.props
---

<CharacterCardPage character={character} locale={locale} />
