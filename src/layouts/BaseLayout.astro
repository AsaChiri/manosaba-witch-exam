---
/*
 * Document shell. Imports tokens + latin fonts + global + card styles; sets
 * <html lang>; renders the SEO head. Per-locale CJK font bundles are imported
 * by each page's frontmatter so they split per locale (unicode-range keeps
 * downloads minimal either way).
 */
import '../styles/tokens.css'
import '../styles/fonts-latin.css'
import '../styles/global.css'
import '../styles/witch-card.css'
import SEOHead from '../components/SEOHead.astro'
import { HTML_LANG, type Locale } from '../i18n/config'
import { t } from '../i18n'

interface SEO {
  routeKey: string
  title: string
  description: string
  ogImage: string
  ogType?: 'website' | 'article'
  jsonld?: ('website' | 'quiz' | 'creativework')[]
  workName?: string
  noindex?: boolean
}
interface Props {
  locale: Locale
  seo: SEO
  bodyClass?: string
}
const { locale, seo, bodyClass } = Astro.props
---

<!doctype html>
<html lang={HTML_LANG[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0d0b10" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <SEOHead locale={locale} {...seo} />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">{t(locale, 'nav.skipToContent')}</a>
    <slot />
    <style>
      .skip-link {
        position: fixed;
        top: 0;
        left: 50%;
        transform: translate(-50%, -120%);
        z-index: 100;
        background: var(--velvet-raised);
        color: var(--verdict-gold);
        padding: 0.6rem 1.2rem;
        border: 1px solid var(--hairline);
        font-family: var(--font-instrument);
        letter-spacing: 0.08em;
        transition: transform 160ms var(--ease-ceremony);
      }
      .skip-link:focus {
        transform: translate(-50%, 0.6rem);
      }
    </style>
  </body>
</html>
