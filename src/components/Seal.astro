---
/*
 * The Verdict Seal — the site's signature crest (design spec §2.3).
 *   engraved annulus ring  (ref: UI_ExecutionButton 処刑 ring)
 * + orbital ellipses       (ref: the 魔法 orbital-ring seals, UI_Trial atlas)
 * + stained-glass rosette  (ref: RefuteCutIn_StainedGlass_003)
 *
 * Stroke-based, currentColor-able, sharp from 24px to 320px. It is the
 * logomark, the verdict stamp, the card crest and the OG brand mark — one
 * memorable element, reused coherently.
 */
interface Props {
  size?: number | string
  title?: string
  /** Add stained-glass tint to the rosette core (landing hero / OG). */
  stained?: boolean
  /** Soft outer glow in currentColor (verdict stamp). */
  glow?: boolean
  class?: string
}

const {
  size = '1em',
  title,
  stained = false,
  glow = false,
  class: className,
} = Astro.props

const dim = typeof size === 'number' ? `${size}px` : size

// ── Geometry (viewBox 0..100, centre 50,50) ──
const C = 50
// Engraved radial ticks between the two annulus circles.
const ticks = Array.from({ length: 60 }, (_, i) => (i * 360) / 60)
// Beading dots.
const beads = Array.from({ length: 24 }, (_, i) => {
  const a = ((i * 360) / 24 - 90) * (Math.PI / 180)
  return { x: C + 40 * Math.cos(a), y: C + 40 * Math.sin(a) }
})
// Orbital ellipses (the arcane orbit-seal look).
const orbits = [0, 60, 120]
// Rosette petals — 12 outer, 6 inner.
const petal = (R: number, halfW: number, waist: number) =>
  `M${C} ${C} Q${C + halfW} ${C - R * waist}, ${C} ${C - R} Q${C - halfW} ${C - R * waist}, ${C} ${C} Z`
const outerPetals = Array.from({ length: 12 }, (_, i) => (i * 360) / 12)
const innerPetals = Array.from({ length: 6 }, (_, i) => (i * 360) / 6 + 30)

const uid = 'seal-' + Math.random().toString(36).slice(2, 8)
---

<svg
  class:list={['seal', className]}
  width={dim}
  height={dim}
  viewBox="0 0 100 100"
  role={title ? 'img' : 'presentation'}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  {title && <title>{title}</title>}
  <defs>
    <radialGradient id={`${uid}-core`} cx="50%" cy="50%" r="55%">
      <stop offset="0%" stop-color="var(--seal-rose, #eb8b79)" stop-opacity={stained ? 0.9 : 0} />
      <stop offset="55%" stop-color="var(--seal-cobalt, #4f86b8)" stop-opacity={stained ? 0.5 : 0} />
      <stop offset="100%" stop-color="var(--seal-cobalt, #4f86b8)" stop-opacity="0" />
    </radialGradient>
    {glow && (
      <filter id={`${uid}-glow`} x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="1.6" result="b" />
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    )}
  </defs>

  <g
    stroke="currentColor"
    stroke-width="1.1"
    stroke-linecap="round"
    filter={glow ? `url(#${uid}-glow)` : undefined}
  >
    <!-- Engraved annulus: two rules + fine radial ticks + beading -->
    <circle cx="50" cy="50" r="47.5" stroke-width="1.3" />
    <circle cx="50" cy="50" r="43" stroke-width="0.7" opacity="0.85" />
    <circle cx="50" cy="50" r="34" stroke-width="0.5" opacity="0.5" />
    <g stroke-width="0.5" opacity="0.6">
      {ticks.map((a) => (
        <line x1="50" y1="4.5" x2="50" y2="7.2" transform={`rotate(${a} 50 50)`} />
      ))}
    </g>
    {stained && <circle cx="50" cy="50" r="21.5" fill={`url(#${uid}-core)`} stroke="none" />}
    <g fill="currentColor" stroke="none" opacity="0.75">
      {beads.map((b) => <circle cx={b.x} cy={b.y} r="0.7" />)}
    </g>

    <!-- Orbital ellipses -->
    <g stroke-width="0.75" opacity="0.68">
      {orbits.map((r) => (
        <ellipse cx="50" cy="50" rx="30" ry="12" transform={`rotate(${r} 50 50)`} />
      ))}
    </g>

    <!-- Rosette core -->
    <g stroke-width="0.8" opacity="0.92">
      {outerPetals.map((a) => (
        <path d={petal(20, 4.4, 0.42)} transform={`rotate(${a} 50 50)`} />
      ))}
    </g>
    <g stroke-width="0.7" opacity="0.8">
      {innerPetals.map((a) => (
        <path d={petal(10.5, 3.1, 0.4)} transform={`rotate(${a} 50 50)`} />
      ))}
    </g>
    <circle cx="50" cy="50" r="2.6" fill="currentColor" stroke="none" />
    <circle cx="50" cy="50" r="5.2" stroke-width="0.6" opacity="0.7" />
  </g>
</svg>

<style>
  .seal {
    display: inline-block;
    color: var(--seal-color, currentColor);
    overflow: visible;
    flex: none;
  }
</style>
