---
/*
 * Card frame — a black frame with silver/gold fleuron corner-scrolls and
 * hairline double-rules (design spec §2.3). Styles live in the shared
 * styles/witch-card.css so the Vue result renders an identical frame. The
 * corner fleuron is authored once and flipped to all four corners.
 */
interface Props {
  class?: string
  tone?: string
  surface?: string
}
const { class: className, tone = 'var(--verdict-gold)', surface = 'var(--velvet)' } = Astro.props
const corners = ['tl', 'tr', 'bl', 'br'] as const
---

<div class:list={['card-frame', className]} style={`--frame-tone:${tone};--frame-surface:${surface};`}>
  <div class="card-frame__rule">
    {corners.map((c) => (
      <svg class={`card-frame__fleuron card-frame__fleuron--${c}`} width="52" height="52" viewBox="0 0 52 52" aria-hidden="true" fill="none">
        <path d="M3 49 L3 15 Q3 3 15 3 L49 3" stroke="currentColor" stroke-width="1.1" opacity="0.9" />
        <path d="M9 49 L9 17 Q9 9 17 9 L49 9" stroke="currentColor" stroke-width="0.6" opacity="0.45" />
        <path d="M15 33 C15 23, 23 15, 33 15" stroke="currentColor" stroke-width="0.8" opacity="0.8" />
        <path d="M15 33 C19 27, 21 25, 20 20 M15 33 C21 29, 23 31, 28 30" stroke="currentColor" stroke-width="0.7" opacity="0.7" />
        <circle cx="16" cy="16" r="1.7" fill="currentColor" opacity="0.85" />
      </svg>
    ))}
    <div class="card-frame__inner">
      <slot />
    </div>
  </div>
</div>
