---
/*
 * Per-page SEO head (design spec §7). Emits localized title/description,
 * canonical, hreflang alternates for THIS page across all 4 locales + x-default
 * (fixes v1's root-only gap), og:*, twitter:card, and JSON-LD. `routeKey` is the
 * locale-relative path ('/', '/exam/', '/r/<tag>/') — the same key is prefixed
 * per locale for alternates.
 */
import {
  LOCALES,
  HTML_LANG,
  OG_LOCALE,
  HREFLANG,
  DEFAULT_LOCALE,
  localePath,
  type Locale,
} from '../i18n/config'
import { t } from '../i18n'

type JsonLd = 'website' | 'quiz' | 'creativework'
interface Props {
  locale: Locale
  routeKey: string
  title: string
  description: string
  ogImage: string
  ogType?: 'website' | 'article'
  jsonld?: JsonLd[]
  /** CreativeWork name for card pages. */
  workName?: string
  /** Keep the page out of search (unadvertised routes). */
  noindex?: boolean
}
const {
  locale,
  routeKey,
  title,
  description,
  ogImage,
  ogType = 'website',
  jsonld = [],
  workName,
  noindex = false,
} = Astro.props

const site = Astro.site ?? new URL('https://manosaba-witch-exam.pages.dev')
const abs = (p: string) => new URL(p, site).href
const canonical = abs(localePath(locale, routeKey))
const ogImageUrl = abs(ogImage)
const siteName = t(locale, 'meta.siteName')

const alternates = LOCALES.map((loc) => ({
  hreflang: HREFLANG[loc],
  href: abs(localePath(loc, routeKey)),
  ogLocale: OG_LOCALE[loc],
}))
const xDefault = abs(localePath(DEFAULT_LOCALE, routeKey))

const graph: Record<string, unknown>[] = []
if (jsonld.includes('website')) {
  graph.push({
    '@type': 'WebSite',
    name: siteName,
    url: canonical,
    inLanguage: HTML_LANG[locale],
    description,
  })
}
if (jsonld.includes('quiz')) {
  graph.push({
    '@type': 'Quiz',
    name: title,
    url: canonical,
    inLanguage: HTML_LANG[locale],
    about: { '@type': 'Thing', name: siteName },
    educationalUse: 'self-assessment',
  })
}
if (jsonld.includes('creativework')) {
  graph.push({
    '@type': 'CreativeWork',
    name: workName ?? title,
    headline: workName ?? title,
    url: canonical,
    inLanguage: HTML_LANG[locale],
    isPartOf: { '@type': 'WebSite', name: siteName, url: abs(localePath(locale, '/')) },
    image: ogImageUrl,
  })
}
const jsonLdBlock =
  graph.length > 0
    ? JSON.stringify({ '@context': 'https://schema.org', '@graph': graph })
    : null
---

<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, follow" />}
<link rel="canonical" href={canonical} />

{alternates.map((a) => (
  <link rel="alternate" hreflang={a.hreflang} href={a.href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefault} />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={OG_LOCALE[locale]} />
{alternates
  .filter((a) => a.ogLocale !== OG_LOCALE[locale])
  .map((a) => <meta property="og:locale:alternate" content={a.ogLocale} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{jsonLdBlock && <script type="application/ld+json" is:inline set:html={jsonLdBlock} />}
