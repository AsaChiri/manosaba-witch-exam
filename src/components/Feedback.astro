---
/*
 * Feedback block (design spec §6). A single mailto: link with a prefilled
 * subject `[魔女因子検査] <tag> / q<quizVersion> / <locale>` + body template.
 * Address from PUBLIC_FEEDBACK_EMAIL (placeholder invalid) and never shown.
 */
import { t } from '../i18n'
import type { Locale } from '../i18n/config'

interface Props {
  locale: Locale
  tag: string
  quizVersion: string
  variant?: 'prominent' | 'quiet'
}
const { locale, tag, quizVersion, variant = 'quiet' } = Astro.props

const email = import.meta.env.PUBLIC_FEEDBACK_EMAIL || 'witch-exam-feedback@asachiri.com'
const subject = t(locale, 'feedback.mailSubject', { tag, quiz: quizVersion, locale })
const body = t(locale, 'feedback.mailBody')
const mailto = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`
---

<section class:list={['feedback', `feedback--${variant}`]} lang={locale}>
  <p class="feedback__invite">{t(locale, 'feedback.invite')}</p>
  <a class="feedback__write" href={mailto}>{t(locale, 'feedback.write')}</a>
</section>

<style>
  .feedback {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .feedback--prominent {
    padding: 1.4rem 1.5rem;
    border: 1px solid var(--hairline-faint);
    background: color-mix(in srgb, var(--velvet) 70%, transparent);
  }
  .feedback__invite {
    color: var(--bone-dim);
    font-size: 0.98rem;
  }
  .feedback--quiet .feedback__invite {
    font-size: 0.88rem;
    color: var(--bone-faint);
  }
  .feedback__write {
    font-family: var(--font-instrument);
    letter-spacing: 0.08em;
    color: var(--verdict-gold);
    text-decoration: none;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 1px;
  }
  .feedback__write:hover {
    color: var(--verdict-gold-bright);
  }
</style>
