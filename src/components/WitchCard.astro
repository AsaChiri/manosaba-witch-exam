---
/*
 * The 魔女図鑑 card, rendered from content (design spec §3.5). Used by the
 * static card share page and the landing specimen preview. The interactive
 * result re-uses the same classes (styles/witch-card.css) inside the Vue island.
 */
import Seal from './Seal.astro'
import { t } from '../i18n'
import type { Locale } from '../i18n/config'
import { cardTitle, type Card } from '../lib/content-schema'

interface Props {
  card: Card
  locale: Locale
  /** Resolved witch name; defaults to the diegetic Nameless Witch. */
  witchName?: string
  class?: string
}
const { card, locale, witchName, class: className } = Astro.props
const name = witchName && witchName.length ? witchName : t(locale, 'card.nameless')
const L = (k: string) => t(locale, `card.labels.${k}`)
// The headline is the magic's name (canon: a witch is known by her magic).
const title = cardTitle(card)
---

<article class:list={['witch-card', className]} lang={locale}>
  <div class="witch-card__crest">
    <Seal size={72} stained title={t(locale, 'meta.siteName')} />
  </div>

  <p class="witch-card__specimen">
    <span class="witch-card__specimen-label">{t(locale, 'card.specimenLabel')}</span>
    &nbsp;·&nbsp;{name}
  </p>

  <div class="witch-card__epithet-block">
    <h2 class="witch-card__epithet">{title}</h2>
  </div>

  <hr class="witch-card__divider" />

  <section class="witch-card__field">
    <span class="witch-card__field-label">{L('epithet')}</span>
    <p class="witch-card__field-body">{card.epithet}</p>
  </section>

  <section class="witch-card__field">
    <span class="witch-card__field-label">{L('magic')}</span>
    <p class="witch-card__field-body">{card.magic.text}</p>
  </section>

  <section class="witch-card__field">
    <span class="witch-card__field-label">{L('crime')}</span>
    <div class="witch-card__prose">{card.crime.map((line) => <p>{line}</p>)}</div>
  </section>

  <section class="witch-card__field">
    <span class="witch-card__field-label">{L('execution')}</span>
    <div class="witch-card__prose">{card.execution.map((line) => <p>{line}</p>)}</div>
  </section>

  <section class="witch-card__field" style="text-align:center">
    <p class="witch-card__epitaph">{card.epitaph}</p>
  </section>
</article>
