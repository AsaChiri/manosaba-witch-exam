---
/*
 * Examination route (design spec §3.2). Hosts the single Vue island
 * (client:only) with the content package it scores against. No footer — the
 * island owns the full-height flow.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import ExamIsland from '../components/exam/ExamIsland.vue'
import Seal from '../components/Seal.astro'
import { t } from '../i18n'
import { localePath, ASTRO_SEGMENT, type Locale } from '../i18n/config'
import {
  getContentMeta,
  getAssetsVersion,
  listCharacters,
  CONTENT_HASH,
} from '../lib/content'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
const meta = getContentMeta()

/* Delivery contract (design spec §5, 2026-07-16): the island receives NO card
 * prose and no cell list — it fetches the one resolved card from /data/ at
 * result time (payload stays O(1) as the corpus grows to ~1,200 tags). The
 * only per-corpus data is the 13-entry character trigger map: tag → {id,
 * magicName}, magicName so the verdict teaser is fetch-independent. The
 * record's prose is fetched on an actual exact-hit trigger, never inlined. */
const characterHits = Object.fromEntries(
  listCharacters(locale).map((c) => [c.tag, { id: c.id, magicName: c.magicName }]),
)

const seo = {
  routeKey: '/exam/',
  title: `${t(locale, 'meta.siteName')} · ${t(locale, 'landing.ctaBegin')}`,
  description: t(locale, 'meta.descExam'),
  ogImage: `/og/${ASTRO_SEGMENT[locale]}/root.png`,
  ogType: 'website' as const,
  jsonld: [] as ('website' | 'quiz' | 'creativework')[],
}
---

<BaseLayout locale={locale} seo={seo} bodyClass="exam-body">
  <a class="exam-home" href={localePath(locale, '/')} aria-label={t(locale, 'nav.home')}>
    <Seal size={24} title={t(locale, 'meta.siteName')} />
  </a>
  <main id="main">
    <ExamIsland
      client:only="vue"
      locale={locale}
      quizVersion={meta.quizVersion}
      contentHash={CONTENT_HASH}
      assetsVersion={getAssetsVersion()}
      characterHits={characterHits}
    />
  </main>
</BaseLayout>

<style>
  .exam-home {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 30;
    color: var(--verdict-gold-deep);
    opacity: 0.55;
    transition: opacity 200ms, color 200ms;
  }
  .exam-home:hover {
    opacity: 1;
    color: var(--verdict-gold);
  }
</style>
