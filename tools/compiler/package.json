{
  "name": "@manosaba/witch-exam-compiler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Compiles authored Manosaba workspace markdown into the runtime content/ package.",
  "license": "UNLICENSED",
  "bin": {
    "compile-content": "./src/compile-content.ts"
  },
  "scripts": {
